<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="100dp"
        android:clipToPadding="false">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- 1. Custom Top Navigation Bar -->
            <RelativeLayout
                android:id="@+id/topBar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:paddingHorizontal="20dp"
                app:layout_constraintTop_toTopOf="parent">
                <ImageView android:id="@+id/btnBack" android:layout_width="24dp" android:layout_height="24dp" android:layout_centerVertical="true" android:src="@drawable/ic_back" app:tint="@color/black" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true" android:fontFamily="@font/jakarta_bold" android:text="Detail Product" android:textColor="@color/black" android:textSize="18sp" />
                <ImageView android:id="@+id/btnShare" android:layout_width="24dp" android:layout_height="24dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_notification" app:tint="@color/black" />
            </RelativeLayout>

            <!-- 2. Main Product Image -->
            <androidx.cardview.widget.CardView
                android:id="@+id/imageContainer"
                android:layout_width="match_parent"
                android:layout_height="350dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/topBar">
                <ImageView android:id="@+id/productDetailImage" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/white" android:padding="32dp" android:scaleType="centerInside" />
            </androidx.cardview.widget.CardView>

            <!-- Dots Indicator -->
            <LinearLayout
                android:id="@+id/dotsIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/imageContainer">
                <View android:layout_width="8dp" android:layout_height="8dp" android:layout_margin="4dp" android:background="@drawable/circle_accent" />
                <View android:layout_width="8dp" android:layout_height="8dp" android:layout_margin="4dp" android:background="@color/text_secondary" android:alpha="0.3" />
                <View android:layout_width="8dp" android:layout_height="8dp" android:layout_margin="4dp" android:background="@color/text_secondary" android:alpha="0.3" />
            </LinearLayout>

            <!-- 3. Basic Info -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/basicInfoSection"
                android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:paddingHorizontal="20dp"
                app:layout_constraintTop_toBottomOf="@id/dotsIndicator">
                <TextView android:id="@+id/productDetailName" android:layout_width="0dp" android:layout_height="wrap_content" android:fontFamily="@font/jakarta_bold" android:text="Product Name" android:textColor="@color/black" android:textSize="22sp" app:layout_constraintEnd_toStartOf="@+id/productDetailPrice" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
                <TextView android:id="@+id/productDetailPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/jakarta_bold" android:text="$ 0.00" android:textColor="@color/black" android:textSize="22sp" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" />
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:gravity="center_vertical" android:orientation="horizontal" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/productDetailName">
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_star" />
                    <TextView android:id="@+id/productDetailRating" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:fontFamily="@font/inter_medium" android:text="4.8" android:textColor="@color/black" android:textSize="14sp" />
                    <TextView android:id="@+id/productDetailSoldCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:fontFamily="@font/inter_regular" android:text="|  Sold 250+" android:textColor="@color/text_secondary" android:textSize="14sp" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 4. Specifications Section -->
            <TextView android:id="@+id/labelDetailTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="32dp" android:fontFamily="@font/jakarta_bold" android:paddingHorizontal="20dp" android:text="Detail Product" android:textColor="@color/black" android:textSize="18sp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/basicInfoSection" />
            <LinearLayout android:id="@+id/specsContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:orientation="vertical" android:paddingHorizontal="20dp" app:layout_constraintTop_toBottomOf="@id/labelDetailTitle">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Condition" android:textColor="@color/text_secondary" android:textSize="14sp" android:fontFamily="@font/inter_regular"/>
                    <TextView android:id="@+id/specCondition" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="100dp" android:text=": New" android:textColor="@color/black" android:textSize="14sp" android:fontFamily="@font/inter_medium"/>
                </RelativeLayout>
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Weight" android:textColor="@color/text_secondary" android:textSize="14sp" android:fontFamily="@font/inter_regular"/>
                    <TextView android:id="@+id/specWeight" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="100dp" android:text=": 500 Gram" android:textColor="@color/black" android:textSize="14sp" android:fontFamily="@font/inter_medium"/>
                </RelativeLayout>
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Category" android:textColor="@color/text_secondary" android:textSize="14sp" android:fontFamily="@font/inter_regular"/>
                    <TextView android:id="@+id/specCategory" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="100dp" android:text=": Smartphone" android:textColor="@color/purple_accent" android:textSize="14sp" android:fontFamily="@font/inter_medium"/>
                </RelativeLayout>
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Brand" android:textColor="@color/text_secondary" android:textSize="14sp" android:fontFamily="@font/inter_regular"/>
                    <TextView android:id="@+id/specBrand" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="100dp" android:text=": XIAOMI" android:textColor="@color/black" android:textSize="14sp" android:fontFamily="@font/inter_medium"/>
                </RelativeLayout>
            </LinearLayout>

            <!-- 5. Description Section -->
            <TextView android:id="@+id/productDetailDescription" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:fontFamily="@font/inter_regular" android:lineSpacingExtra="4dp" android:paddingHorizontal="20dp" android:text="Product description..." android:textColor="@color/black" android:textSize="14sp" app:layout_constraintTop_toBottomOf="@id/specsContainer" />
            <TextView android:id="@+id/btnMoreInfo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:fontFamily="@font/inter_bold" android:paddingHorizontal="20dp" android:text="More Information" android:textColor="@color/purple_accent" android:textSize="14sp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/productDetailDescription" />

            <!-- 6. Color Selection -->
            <TextView android:id="@+id/labelChooseColor" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="32dp" android:fontFamily="@font/jakarta_bold" android:paddingHorizontal="20dp" android:text="Choose Color" android:textColor="@color/black" android:textSize="18sp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/btnMoreInfo" />
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/colorRecyclerView" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:clipToPadding="false" android:orientation="horizontal" android:paddingHorizontal="20dp" app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" app:layout_constraintTop_toBottomOf="@id/labelChooseColor" />

            <!-- 7. Reviews Section -->
            <TextView android:id="@+id/labelReviews" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="32dp" android:fontFamily="@font/jakarta_bold" android:paddingHorizontal="20dp" android:text="Reviews" android:textColor="@color/black" android:textSize="18sp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/colorRecyclerView" />
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/reviewsRecyclerView" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:nestedScrollingEnabled="false" android:paddingHorizontal="20dp" app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" app:layout_constraintTop_toBottomOf="@id/labelReviews" />

            <!-- 8. Store Info -->
            <TextView android:id="@+id/labelStoreInfo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="32dp" android:fontFamily="@font/jakarta_bold" android:paddingHorizontal="20dp" android:text="Store Information" android:textColor="@color/black" android:textSize="18sp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/reviewsRecyclerView" />
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:paddingHorizontal="20dp" app:layout_constraintTop_toBottomOf="@id/labelStoreInfo">
                <androidx.cardview.widget.CardView android:id="@+id/storeImageContainer" android:layout_width="48dp" android:layout_height="48dp" app:cardCornerRadius="24dp" app:cardElevation="0dp">
                    <ImageView android:id="@+id/storeImage" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_product_image_grey" />
                </androidx.cardview.widget.CardView>
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_marginStart="12dp" android:layout_toEndOf="@id/storeImageContainer" android:orientation="vertical">
                    <TextView android:id="@+id/storeName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/inter_bold" android:text="Alfinas Store" android:textColor="@color/black" android:textSize="14sp" />
                    <TextView android:id="@+id/storeLocation" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/inter_regular" android:text="Online . North Jakarta" android:textColor="@color/text_secondary" android:textSize="12sp" />
                </LinearLayout>
                <Button android:id="@+id/btnFollowStore" android:layout_width="wrap_content" android:layout_height="36dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:backgroundTint="@color/white" android:fontFamily="@font/inter_medium" android:paddingHorizontal="16dp" android:text="Follow" android:textAllCaps="false" android:textColor="@color/black" android:textSize="12sp" app:cornerRadius="8dp" app:strokeColor="#E0E0E0" app:strokeWidth="1dp" />
            </RelativeLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 9. Fixed Bottom Action Bar -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_gravity="bottom"
        app:cardCornerRadius="0dp"
        app:cardElevation="16dp">
        <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:paddingHorizontal="20dp" android:background="@color/white">
            <ImageView android:id="@+id/btnChat" android:layout_width="48dp" android:layout_height="48dp" android:layout_centerVertical="true" android:background="@drawable/bg_category" android:padding="12dp" android:src="@drawable/search" app:tint="@color/black" />
            <Button android:id="@+id/btnAddToCart" android:layout_width="match_parent" android:layout_height="50dp" android:layout_centerVertical="true" android:layout_marginStart="16dp" android:layout_toEndOf="@id/btnChat" android:backgroundTint="@color/black" android:fontFamily="@font/jakarta_bold" android:text="Add to Cart" android:textAllCaps="false" android:textColor="@color/white" android:textSize="16sp" app:cornerRadius="12dp" />
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>