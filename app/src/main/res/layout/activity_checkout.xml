<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- Top Bar -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:paddingHorizontal="20dp"
        android:background="@color/white"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back"
            app:tint="@color/black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/jakarta_bold"
            android:text="Secure Checkout"
            android:textColor="@color/black"
            android:textSize="18sp" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:layout_above="@id/bottomBarCard"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Items Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/jakarta_bold"
                android:text="Your Items"
                android:textColor="@color/black"
                android:textSize="16sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/checkoutRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false" />

            <!-- Promo Code Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/jakarta_bold"
                android:text="Promo Code"
                android:textColor="@color/black"
                android:textSize="16sp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <EditText
                    android:id="@+id/etPromoCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_payment_selector"
                    android:hint="Enter promo code"
                    android:padding="16dp"
                    android:paddingEnd="80dp"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/btnApplyPromo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="16dp"
                    android:fontFamily="@font/jakarta_bold"
                    android:text="APPLY"
                    android:textColor="@color/black"
                    android:textSize="14sp" />
            </RelativeLayout>

            <!-- Shipping Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/jakarta_bold"
                android:text="Shipping Address"
                android:textColor="@color/black"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/etAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_payment_selector"
                android:hint="House #, Street, City..."
                android:padding="16dp"
                android:textSize="14sp" />

            <!-- Payment Methods Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/jakarta_bold"
                android:text="Payment Method"
                android:textColor="@color/black"
                android:textSize="16sp" />

            <RadioGroup
                android:id="@+id/rgPaymentMethods"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <RadioButton
                    android:id="@+id/rbJazzCash"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_payment_selector"
                    android:button="@null"
                    android:drawableStart="@android:drawable/ic_menu_agenda"
                    android:drawablePadding="16dp"
                    android:paddingHorizontal="20dp"
                    android:text="JazzCash Account\n03XX-XXXXXXX"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/rbEasyPaisa"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_payment_selector"
                    android:button="@null"
                    android:drawableStart="@android:drawable/ic_menu_call"
                    android:drawablePadding="16dp"
                    android:paddingHorizontal="20dp"
                    android:text="EasyPaisa Wallet\n03XX-XXXXXXX"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/rbNayaPay"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_payment_selector"
                    android:button="@null"
                    android:drawableStart="@android:drawable/ic_menu_send"
                    android:drawablePadding="16dp"
                    android:paddingHorizontal="20dp"
                    android:text="NayaPay\nLinked: Rs. 15,200.00"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/rbSadaPay"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_payment_selector"
                    android:button="@null"
                    android:drawableStart="@android:drawable/ic_menu_recent_history"
                    android:drawablePadding="16dp"
                    android:paddingHorizontal="20dp"
                    android:text="SadaPay Account\nBalance: Rs. 8,450.00"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/rbCOD"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:background="@drawable/bg_payment_selector"
                    android:button="@null"
                    android:checked="true"
                    android:drawableStart="@android:drawable/ic_menu_mylocation"
                    android:drawablePadding="16dp"
                    android:paddingHorizontal="20dp"
                    android:text="Cash on Delivery\nPay when you receive"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

            </RadioGroup>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Action Bar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottomBarCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        app:cardElevation="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@color/white">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Amount"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="@font/jakarta_medium" />

                <TextView
                    android:id="@+id/tvFinalTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/jakarta_bold"
                    android:text="$ 0.00"
                    android:textColor="@color/black"
                    android:textSize="20sp" />
            </RelativeLayout>

            <Button
                android:id="@+id/btnOrderNow"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="@color/black"
                android:fontFamily="@font/jakarta_bold"
                android:text="CONFIRM AND PAY"
                android:textSize="16sp"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</RelativeLayout>