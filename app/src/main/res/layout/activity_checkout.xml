<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- Top Bar (Fixed) -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:paddingHorizontal="20dp"
        android:background="@color/bg_light"
        android:elevation="2dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back"
            app:tint="@color/black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/jakarta_bold"
            android:text="Checkout"
            android:textColor="@color/black"
            android:textSize="18sp" />
    </RelativeLayout>

    <!-- Scrollable Content -->
    <!-- layout_above ensures this stops before the bottom bar -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:layout_above="@id/bottomBarCard"
        android:clipToPadding="false"
        android:paddingBottom="20dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Product List Summary -->
            <TextView
                android:id="@+id/labelProductList"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/jakarta_bold"
                android:paddingHorizontal="20dp"
                android:text="Product List"
                android:textColor="@color/black"
                android:textSize="16sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/checkoutRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="20dp"
                app:layout_constraintTop_toBottomOf="@id/labelProductList" />

            <!-- Shipping Section -->
            <TextView
                android:id="@+id/labelShipping"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/jakarta_bold"
                android:paddingHorizontal="20dp"
                android:text="Shipping"
                android:textColor="@color/black"
                android:textSize="16sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/checkoutRecyclerView" />

            <EditText
                android:id="@+id/etAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_search_bar"
                android:fontFamily="@font/inter_regular"
                android:gravity="top"
                android:hint="Enter your full address..."
                android:minHeight="80dp"
                android:padding="16dp"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/labelShipping" />

            <!-- Promo Section -->
            <TextView
                android:id="@+id/labelPromo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/jakarta_bold"
                android:paddingHorizontal="20dp"
                android:text="Promos"
                android:textColor="@color/black"
                android:textSize="16sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/etAddress" />

            <LinearLayout
                android:id="@+id/promoContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_search_bar"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                app:layout_constraintTop_toBottomOf="@id/labelPromo">

                <EditText
                    android:id="@+id/etPromoCode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/inter_medium"
                    android:hint="Enter Promo Code"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/btnApplyPromo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_bold"
                    android:padding="8dp"
                    android:text="Apply"
                    android:textColor="@color/purple_accent"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Payment Method Section -->
            <TextView
                android:id="@+id/labelPayment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/jakarta_bold"
                android:paddingHorizontal="20dp"
                android:text="Payment Method"
                android:textColor="@color/black"
                android:textSize="16sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/promoContainer" />

            <RadioGroup
                android:id="@+id/rgPaymentMethods"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp"
                app:layout_constraintTop_toBottomOf="@id/labelPayment"
                app:layout_constraintBottom_toBottomOf="parent">

                <RadioButton
                    android:id="@+id/rbJazzCash"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:fontFamily="@font/inter_medium"
                    android:paddingStart="12dp"
                    android:text="JazzCash"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/rbEasyPaisa"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:fontFamily="@font/inter_medium"
                    android:paddingStart="12dp"
                    android:text="EasyPaisa"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/rbNayaPay"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:fontFamily="@font/inter_medium"
                    android:paddingStart="12dp"
                    android:text="NayaPay"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/rbSadaPay"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:fontFamily="@font/inter_medium"
                    android:paddingStart="12dp"
                    android:text="SadaPay"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/rbBankTransfer"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:fontFamily="@font/inter_medium"
                    android:paddingStart="12dp"
                    android:text="Direct Bank Transfer"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/rbCOD"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:checked="true"
                    android:fontFamily="@font/inter_medium"
                    android:paddingStart="12dp"
                    android:text="Cash on Delivery (COD)"
                    android:textSize="14sp" />
            </RadioGroup>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Fixed Bottom Bar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottomBarCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        app:cardCornerRadius="0dp"
        app:cardElevation="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@color/white">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_regular"
                    android:text="Total Payment"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvFinalTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/jakarta_bold"
                    android:text="$ 0.00"
                    android:textColor="@color/black"
                    android:textSize="18sp" />
            </RelativeLayout>

            <Button
                android:id="@+id/btnOrderNow"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:backgroundTint="@color/black"
                android:fontFamily="@font/jakarta_bold"
                android:text="Order Now"
                android:textAllCaps="false"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</RelativeLayout>